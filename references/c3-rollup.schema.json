{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aaron-he-zhu/aaron-marketing-skills/references/c3-rollup.schema.json",
  "title": "C3 Campaign Value Index Rollup Input",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "scopes": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {"$ref": "#/$defs/scoredResult"}
    },
    "components": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ace", "art", "roi"],
      "properties": {
        "ace": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/aceComponent"}
        },
        "art": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/equalComponent"}
        },
        "roi": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": {"$ref": "#/$defs/equalComponent"}
        }
      }
    }
  },
  "oneOf": [
    {"required": ["scopes"]},
    {"required": ["components"]}
  ],
  "$defs": {
    "scoredResult": {
      "type": "object",
      "required": [
        "framework", "catalog_version", "profile", "target", "observed_at",
        "context", "status", "verdict", "score_state", "evidence_coverage",
        "score_confidence", "veto_count", "cap_applied", "raw_overall_score",
        "final_overall_score"
      ],
      "properties": {
        "framework": {"const": "C3"},
        "catalog_version": {"const": "17.0.0"},
        "profile": {
          "type": "string",
          "pattern": "^(ace|art|roi)-(awareness|engagement|conversion|brand-building)$"
        },
        "target": {"type": "string", "minLength": 1},
        "observed_at": {"type": "string", "format": "date"},
        "context": {
          "type": "object",
          "additionalProperties": false,
          "required": ["scope", "goal", "assessment_time", "rollup_id"],
          "properties": {
            "scope": {"enum": ["ace", "art", "roi"]},
            "goal": {"enum": ["awareness", "engagement", "conversion", "brand-building"]},
            "assessment_time": {"enum": ["forecast", "actual"]},
            "rollup_id": {"type": "string", "minLength": 1, "pattern": "\\S"}
          }
        },
        "status": {"enum": ["DONE", "DONE_WITH_CONCERNS"]},
        "verdict": {"enum": ["SHIP", "FIX"]},
        "score_state": {"const": "SCORED"},
        "evidence_coverage": {"const": 100},
        "score_confidence": {"enum": ["high", "medium", "low"]},
        "veto_count": {"type": "integer", "minimum": 0, "maximum": 1},
        "cap_applied": {"type": "boolean"},
        "raw_overall_score": {"type": "integer", "minimum": 0, "maximum": 100},
        "final_overall_score": {"type": "integer", "minimum": 0, "maximum": 100}
      },
      "allOf": [
        {
          "if": {"properties": {"verdict": {"const": "SHIP"}}, "required": ["verdict"]},
          "then": {
            "properties": {
              "status": {"const": "DONE"},
              "raw_overall_score": {"minimum": 75},
              "veto_count": {"const": 0},
              "cap_applied": {"const": false}
            }
          }
        },
        {
          "if": {"properties": {"verdict": {"const": "FIX"}}, "required": ["verdict"]},
          "then": {"properties": {"status": {"const": "DONE_WITH_CONCERNS"}}}
        },
        {
          "if": {"properties": {"veto_count": {"const": 0}}, "required": ["veto_count"]},
          "then": {"properties": {"cap_applied": {"const": false}}}
        },
        {
          "if": {"properties": {"veto_count": {"const": 1}}, "required": ["veto_count"]},
          "then": {
            "properties": {
              "verdict": {"const": "FIX"},
              "cap_applied": {"const": true},
              "final_overall_score": {
                "maximum": 59,
                "description": "Runtime also requires final_overall_score = min(raw_overall_score, 59)."
              }
            }
          }
        }
      ]
    },
    "aceComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["result"],
      "properties": {
        "result": {"$ref": "#/$defs/scoredResult"},
        "weight": {"type": "number", "exclusiveMinimum": 0}
      }
    },
    "equalComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["result"],
      "properties": {"result": {"$ref": "#/$defs/scoredResult"}}
    }
  }
}
